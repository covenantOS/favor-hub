---
---
<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="Favor International">
      <img src="/images/favor-icon.png" alt="" class="brand__icon" />
      <span class="brand__text">
        <span class="brand__name">Favor International</span>
        <span class="brand__tag">Hub · Mission Control</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <span class="clock" id="clock" aria-hidden="true"></span>
      <button type="button" class="cmdk-trigger" data-cmdk-open aria-label="Search the hub">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="cmdk-trigger__label">Search</span>
        <kbd>⌘K</kbd>
      </button>
      <a href="https://www.favorintl.org" target="_blank" rel="noopener" class="hide-sm">Website</a>
      <a href="https://www.favorintl.org/donate" target="_blank" rel="noopener" class="donate" title="Partner financially">Hold the Ropes</a>
    </nav>
  </div>
</header>

<script is:inline>
  const fmt = new Intl.DateTimeFormat('en-US', {
    weekday: 'short', hour: 'numeric', minute: '2-digit', timeZoneName: 'short'
  });
  const tick = () => {
    const el = document.getElementById('clock');
    if (el) el.textContent = fmt.format(new Date());
  };
  tick();
  setInterval(tick, 30_000);
</script>
